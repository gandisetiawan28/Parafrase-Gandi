<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>9bb7a975-b568-4b2d-9683-39fd2900118f</Id>
  <Version>4.1.0.0</Version>
  <ProviderName>Parafrase Gandi</ProviderName>
  <DefaultLocale>id-ID</DefaultLocale>
  <DisplayName DefaultValue="Parafrase Gandi"/>
  <Description DefaultValue="Parafrase teks terpilih menggunakan AI Gemini (Parafrase Gandi)."/>
  <IconUrl DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/your-repo"/>
  <AppDomains>
    <AppDomain>https://generativelanguage.googleapis.com</AppDomain>
    <AppDomain>https://script.google.com</AppDomain>
    <AppDomain>https://script.googleusercontent.com</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          <ExtensionPoint xsi:type="ContextMenu">
            <OfficeMenu id="ContextMenuText">
              <Control xsi:type="Button" id="ParaphraseButton">
                <Label resid="ParaphraseButton.Label"/>
                <Supertip>
                  <Title resid="ParaphraseButton.Label"/>
                  <Description resid="ParaphraseButton.Tooltip"/>
                </Supertip>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Action xsi:type="ExecuteFunction">
                  <FunctionName>paraphraseAction</FunctionName>
                </Action>
              </Control>
            </OfficeMenu>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812"/>
        <bt:Url id="Commands.Url" DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://gandisetiawan28.github.io/Parafrase-Gandi/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Mulai dengan Parafrase Gandi!" />
        <bt:String id="CommandsGroup.Label" DefaultValue="Parafrase Gandi" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Pengaturan Gandi" />
        <bt:String id="ParaphraseButton.Label" DefaultValue="Parafrase dengan Gandi" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Ekstensi Anda berhasil dimuat. Buka tab BERANDA atau klik kanan teks untuk mulai memparafrase." />
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Klik untuk membuka pengaturan dan API Key." />
        <bt:String id="ParaphraseButton.Tooltip" DefaultValue="Langsung parafrase teks yang di-select." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>